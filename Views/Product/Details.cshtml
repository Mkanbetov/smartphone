@model Smartphone.Models.Product

<h2>@Model.Name</h2>

<div class="row">
    <div class="col-md-4">
        <img src="@Model.ImageUrl"
             class="img-fluid"
             alt="@Model.Name"
              />

    </div>

    <div class="col-md-8">
        <h4>Price: @Model.Price KGS</h4>

        <ul class="list-group mt-3">
            <li class="list-group-item">
                <strong>Brand:</strong> @Model.Brand?.Name
            </li>
            <li class="list-group-item">
                <strong>Category:</strong> @Model.Category?.Name
            </li>
            <li class="list-group-item">
                <strong>Memory:</strong> @Model.Memory GB
            </li>
            <li class="list-group-item">
                <strong>Battery:</strong> @Model.Battery mAh
            </li>
        </ul>

        <a asp-action="Index" class="btn btn-secondary mt-3">Вернуться</a>
        <a asp-controller="Order" asp-action="Create" asp-route-productId="@Model.Id" class="btn btn-primary mt-3">
            Заказать
        </a>

    </div>
</div>

